# ═══ مركز الأذكار - Security Headers ══════════════════════════════════════

/*
  # Force HTTPS - يجبر كل الروابط على HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # منع عرض الموقع داخل iframes من مواقع أخرى
  X-Frame-Options: SAMEORIGIN

  # منع تخمين نوع المحتوى - يحمي من هجمات MIME sniffing
  X-Content-Type-Options: nosniff

  # حماية XSS للمتصفحات القديمة
  X-XSS-Protection: 1; mode=block

  # سياسة مرجعية آمنة
  Referrer-Policy: strict-origin-when-cross-origin

  # تحديد أذونات الميزات
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=(), midi=()

  # Cross-Origin policies للأمان
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

  # ترقية كل الطلبات إلى HTTPS تلقائياً
  Content-Security-Policy: upgrade-insecure-requests; default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https:; font-src 'self' https://fonts.gstatic.com data: https:; img-src 'self' data: blob: https:; connect-src 'self' https://api.aladhan.com https://api.alquran.cloud https://api.quran.com https://everyayah.com https://mp3quran.net https://supabase.co https://*.supabase.co wss://*.supabase.co https://raw.githubusercontent.com https://siimuzrjiobhxftntppr.supabase.co https://cohcnmqarjvoradzlsov.supabase.co https://fonts.googleapis.com https://fonts.gstatic.com https://restcountries.com https:; media-src 'self' blob: https://everyayah.com https://mp3quran.net https://raw.githubusercontent.com https:; worker-src 'self' blob:; manifest-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self';

  # منع تحميل الموقع في FrameOptions
  X-Permitted-Cross-Domain-Policies: none

  # Cache للصفحات الرئيسية
  Cache-Control: no-cache

# ═══ Service Worker ════════════════════════════════════════════════════════
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /
  X-Content-Type-Options: nosniff

# ═══ PWA Manifest ══════════════════════════════════════════════════════════
/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400

# ═══ Static Assets (immutable cache) ══════════════════════════════════════
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# ═══ Audio files ══════════════════════════════════════════════════════════
/audio/*
  Cache-Control: public, max-age=2592000
  Accept-Ranges: bytes
  Cross-Origin-Resource-Policy: cross-origin

# ═══ Data files ════════════════════════════════════════════════════════════
/data/*
  Cache-Control: public, max-age=604800

# ═══ Icons ═════════════════════════════════════════════════════════════════
/icon-*.png
  Cache-Control: public, max-age=31536000, immutable

/favicon*
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# ═══ SEO files ═════════════════════════════════════════════════════════════
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/browserconfig.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=86400
